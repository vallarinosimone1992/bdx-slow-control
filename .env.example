# IOC server interface.
BDX_EPICS_INTERFACE=127.0.0.1
BDX_LOG_LEVEL=INFO

# Optional absolute or relative path to phoebus.sh.
# Example for the directory layout used during development:
# BDX_PHOEBUS_CMD=../preliminary_test_epics/phoebus/phoebus-product/phoebus.sh
BDX_PHOEBUS_CMD=

# Alternative: directory containing phoebus.sh.
BDX_PHOEBUS_HOME=

# macOS alternative, for example /Applications/Phoebus.app.
BDX_PHOEBUS_APP=

# Channel Access client configuration used by Phoebus.
BDX_CA_ADDR_LIST=127.0.0.1
BDX_CA_AUTO_ADDR_LIST=false
BDX_CA_SERVER_PORT=5064
BDX_CA_REPEATER_PORT=5065

# Phoebus display update throttle. 2000 ms corresponds to at most 0.5 Hz.
BDX_PHOEBUS_UPDATE_THROTTLE_MS=2000

# Default time range for strip-chart widgets.
BDX_TREND_RANGE=10 minutes

# Display name or path opened by the launcher.
BDX_PHOEBUS_DISPLAY=overview
