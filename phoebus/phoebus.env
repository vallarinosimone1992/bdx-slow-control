# Copy this file to phoebus/phoebus.env and edit it for the local machine.

# Path to the Phoebus launcher. Relative paths are resolved from the repository root.
BDX_PHOEBUS_CMD="${BDX_PHOEBUS_CMD:-}"

# Alternative directory containing phoebus.sh.
BDX_PHOEBUS_HOME="${BDX_PHOEBUS_HOME:-}"

# macOS application bundle alternative.
BDX_PHOEBUS_APP="${BDX_PHOEBUS_APP:-}"

BDX_MAIN_HOST="${BDX_MAIN_HOST:-127.0.0.1}"
BDX_CA_ADDR_LIST="${BDX_CA_ADDR_LIST:-$BDX_MAIN_HOST 172.22.50.10}"
BDX_CA_AUTO_ADDR_LIST="${BDX_CA_AUTO_ADDR_LIST:-false}"
BDX_CA_SERVER_PORT="${BDX_CA_SERVER_PORT:-5064}"
BDX_CA_REPEATER_PORT="${BDX_CA_REPEATER_PORT:-5065}"
BDX_PHOEBUS_UPDATE_THROTTLE_MS="${BDX_PHOEBUS_UPDATE_THROTTLE_MS:-1000}"
BDX_TREND_RANGE="${BDX_TREND_RANGE:-10 minutes}"
BDX_TREND_SCAN_PERIOD="${BDX_TREND_SCAN_PERIOD:-1.0}"
BDX_TREND_RING_SIZE="${BDX_TREND_RING_SIZE:-5000}"
BDX_TREND_ARCHIVE_REQUEST="${BDX_TREND_ARCHIVE_REQUEST:-RAW}"
BDX_PHOEBUS_DISPLAY="${BDX_PHOEBUS_DISPLAY:-overview}"
BDX_ARCHIVER_ENABLED="${BDX_ARCHIVER_ENABLED:-true}"
BDX_ARCHIVER_URL="${BDX_ARCHIVER_URL:-http://127.0.0.1:17668/retrieval}"
BDX_ARCHIVER_NAME="${BDX_ARCHIVER_NAME:-BDX Archiver}"
BDX_ARCHIVER_STRICT_CHECK="${BDX_ARCHIVER_STRICT_CHECK:-false}"
BDX_ARCHIVER_PREFLIGHT_PV="${BDX_ARCHIVER_PREFLIGHT_PV:-}"
