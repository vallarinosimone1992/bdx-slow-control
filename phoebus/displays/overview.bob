<?xml version='1.0' encoding='UTF-8'?>
<display version="2.0.0">
  <name>BDX Slow Control Overview</name>
  <width>1400</width>
  <height>980</height>
  <widget type="label" version="2.0.0">
    <name>Label_1</name>
    <x>20</x>
    <y>12</y>
    <width>650</width>
    <height>38</height>
