  <widget type="textupdate" version="2.0.0">
    <name>Readback_17</name>
    <x>725</x>
    <y>105</y>
    <width>340</width>
    <height>28</height>
    <pv_name>BDX:GLOBAL:INTERLOCK_REASON</pv_name>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>Action_18</name>
    <x>1080</x>
    <y>105</y>
    <width>135</width>
    <height>28</height>
    <pv_name>BDX:GLOBAL:INTERLOCK_TEST_CMD</pv_name>
    <actions>
      <action type="write_pv">
        <pv_name>BDX:GLOBAL:INTERLOCK_TEST_CMD</pv_name>
        <value>On</value>
        <description>Write On to BDX:GLOBAL:INTERLOCK_TEST_CMD</description>
      </action>
    </actions>
    <text>TEST INTERLOCK</text>
    <tooltip>$(actions)</tooltip>
    <confirm_dialog>true</confirm_dialog>
    <confirm_message>Trigger the simulated interlock and switch PSU/HV outputs off?</confirm_message>
    <background_color>
      <color red="255" green="205" blue="120" />
    </background_color>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>Action_19</name>
    <x>1225</x>
    <y>105</y>
    <width>75</width>
    <height>28</height>
    <pv_name>BDX:GLOBAL:INTERLOCK_RESET_CMD</pv_name>
    <actions>
      <action type="write_pv">
        <pv_name>BDX:GLOBAL:INTERLOCK_RESET_CMD</pv_name>
        <value>On</value>
        <description>Write On to BDX:GLOBAL:INTERLOCK_RESET_CMD</description>
      </action>
    </actions>
