    <tooltip>$(actions)</tooltip>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>Action_20</name>
    <x>1310</x>
    <y>105</y>
    <width>75</width>
    <height>28</height>
    <pv_name>BDX:GLOBAL:ALLOFF_CMD</pv_name>
    <actions>
      <action type="write_pv">
        <pv_name>BDX:GLOBAL:ALLOFF_CMD</pv_name>
        <value>On</value>
        <description>Write On to BDX:GLOBAL:ALLOFF_CMD</description>
      </action>
    </actions>
    <text>ALL OFF</text>
    <tooltip>$(actions)</tooltip>
    <confirm_dialog>true</confirm_dialog>
    <confirm_message>Switch all simulated PSU and HV channels off?</confirm_message>
    <background_color>
      <color red="255" green="150" blue="150" />
    </background_color>
  </widget>
