{
  "server": {
    "interfaces": [
      "0.0.0.0"
    ],
    "poll_interval": 5.0,
    "log_pv_names": false
  },
  "device": {
    "name": "HV1",
    "prefix": "BDX:HV:HV1:",
    "mode": "hardware",
    "driver": "genh600",
    "port": "/dev/ttyUSB0",
    "baudrate": 9600,
    "address": 6,
    "timeout": 2.0,
    "channels": [
      1
    ],
    "clear_status": true,
    "remote_control": true,
    "identify_on_connect": true,
    "initial_current_limit": 0.001,
    "initial_ovp": 2500.0,
    "initial_ocp": 0.01
  }
}
