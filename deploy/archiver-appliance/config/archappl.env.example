# BDX EPICS Archiver Appliance runtime configuration template.
#
# Copy this file outside the Git checkout, for example to
# /etc/bdx-archiver/archappl.env for a system deployment or to
# ~/.config/bdx-archiver/archappl.env for a user-local deployment.

BDX_ARCHIVER_RELEASE_VERSION=2.3.1
BDX_ARCHIVER_RELEASE_ARTIFACT=archappl_v2.3.1.tar.gz
BDX_ARCHIVER_RELEASE_URL=https://github.com/archiver-appliance/epicsarchiverap/releases/download/2.3.1/archappl_v2.3.1.tar.gz
BDX_ARCHIVER_RELEASE_SHA256=ce2eabe57915a99bc9be22d29d400f112f63931b5d5af9394e8504702d16722f

BDX_MAIN_HOST="${BDX_MAIN_HOST:-127.0.0.1}"

BDX_ARCHIVER_APP_DIR=/opt/bdx-archiver
BDX_ARCHIVER_CONFIG_DIR=/etc/bdx-archiver
BDX_ARCHIVER_STATE_DIR=/var/lib/bdx-archiver
BDX_ARCHIVER_LOG_DIR=/var/log/bdx-archiver
BDX_ARCHIVER_CACHE_DIR=/var/cache/bdx-archiver

BDX_ARCHIVER_TMP_DIR=/var/lib/bdx-archiver/tmp
BDX_ARCHIVER_SHORT_TERM_DIR=/var/lib/bdx-archiver/sts
BDX_ARCHIVER_MEDIUM_TERM_DIR=/var/lib/bdx-archiver/mts
BDX_ARCHIVER_LONG_TERM_DIR=/var/lib/bdx-archiver/lts
BDX_ARCHIVER_PERSISTENCE_DIR=/var/lib/bdx-archiver/persistence

BDX_ARCHIVER_TOMCAT_HOME=/opt/bdx-archiver/tomcat
BDX_ARCHIVER_TOMCAT_TARBALL=
BDX_ARCHIVER_WAR_DIR=/opt/bdx-archiver/war
BDX_ARCHIVER_TOMCAT_BASE_DIR=/var/lib/bdx-archiver/tomcat

BDX_ARCHIVER_APPLIANCE_ID=bdx0
BDX_ARCHIVER_CLUSTER_HOST=127.0.0.1
BDX_ARCHIVER_CLUSTER_PORT=16670
BDX_ARCHIVER_MGMT_HOST=127.0.0.1
BDX_ARCHIVER_ENGINE_HOST=127.0.0.1
BDX_ARCHIVER_ETL_HOST=127.0.0.1
BDX_ARCHIVER_RETRIEVAL_HOST=127.0.0.1
BDX_ARCHIVER_MGMT_PORT=17665
BDX_ARCHIVER_ENGINE_PORT=17666
BDX_ARCHIVER_ETL_PORT=17667
BDX_ARCHIVER_RETRIEVAL_PORT=17668
BDX_ARCHIVER_DATA_RETRIEVAL_URL=http://127.0.0.1:17668/retrieval

BDX_ARCHIVER_MGMT_URL=http://127.0.0.1:17665/mgmt/bpl
BDX_ARCHIVER_ENGINE_URL=http://127.0.0.1:17666/engine/bpl
BDX_ARCHIVER_ETL_URL=http://127.0.0.1:17667/etl/bpl
BDX_ARCHIVER_RETRIEVAL_BPL_URL=http://127.0.0.1:17668/retrieval/bpl
BDX_ARCHIVER_RETRIEVAL_DATA_URL=http://127.0.0.1:17668/retrieval

BDX_ARCHIVER_DEFAULT_POLICY=BDX_Physical_5s
BDX_ARCHIVER_STATE_POLICY=BDX_State_Change
BDX_ARCHIVER_DIAGNOSTIC_POLICY=BDX_Diagnostic_Change

# Register the operational PSU, chiller, and environment archive lists after all four
# Archiver Appliance components are healthy. Set BDX_ARCHIVER_AUTO_REGISTER=false
# to disable this.
BDX_ARCHIVER_AUTO_REGISTER=true
# Leave empty to use $BDX_ARCHIVER_APP_DIR/pv-lists/psu.txt and
# $BDX_ARCHIVER_APP_DIR/pv-lists/chiller.txt and
# $BDX_ARCHIVER_APP_DIR/pv-lists/environment.txt.
BDX_ARCHIVER_PV_LISTS=
BDX_ARCHIVER_REGISTER_RETRY_SECONDS=30

# Medium-term storage uses daily partitions and keeps 60 days by default.
# Long-term storage intentionally has no automatic deletion or hold limit.
BDX_ARCHIVER_MEDIUM_TERM_HOLD_DAYS=60

# Channel Access settings. Fill EPICS_CA_ADDR_LIST with the actual IOC hosts.
# Example for a main server plus Raspberry environment IOC:
# EPICS_CA_ADDR_LIST="172.22.50.2 172.22.50.10"
EPICS_CA_ADDR_LIST="${EPICS_CA_ADDR_LIST:-$BDX_MAIN_HOST 172.22.50.10}"
EPICS_CA_AUTO_ADDR_LIST=NO
EPICS_CA_SERVER_PORT=5064
EPICS_CA_REPEATER_PORT=5065

BDX_ARCHIVER_SERVICE_MODE=system
BDX_ARCHIVER_KNOWN_PV=BDX:ENV:TEMP:T00:VALUE

# Leave unset unless an external persistent database has been configured.
# The quick evaluation mode may use the upstream in-memory persistence layer,
# but persistent BDX deployment must use a configured database or another
# supported persistence layer.
ARCHAPPL_PERSISTENCE_LAYER=
JAVA_OPTS="-Xms1G -Xmx2G -ea"
